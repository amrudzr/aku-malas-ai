{
  "manifest_version": 3,
  "name": "Aku Malas AI — Sidebar Assistant",
  "version": "1.0.0",
  "description": "Asisten AI sidebar modern dengan fitur screenshot dan dukungan banyak model (Gemini, Claude, OpenAI).",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Buka Aku Malas AI"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "minimum_chrome_version": "114"
}
